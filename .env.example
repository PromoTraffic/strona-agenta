# Nazwa agenta (fallback gdy brak w DB)
NEXT_PUBLIC_AGENT_NAME=Agent AI PromoTraffic

# Opcjonalnie: link do głównej strony PromoTraffic (logo / stopka)
# NEXT_PUBLIC_PRIMARY_SITE_URL=https://promotraffic.pl

# URL-e do narzędzi (fallback gdy brak w DB)
# NEXT_PUBLIC_TOOL_MEDIAPULSE_URL=
# NEXT_PUBLIC_TOOL_PRODUCT_GEN_URL=
# NEXT_PUBLIC_TOOL_PROMARKETER_URL=
# NEXT_PUBLIC_TOOL_PROMOTION_AI_URL=
