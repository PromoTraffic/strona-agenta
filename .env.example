# Baza danych (SQLite) — ścieżka do pliku, montuj volume w Docker dla persystencji
# Ścieżka do pliku SQLite (montuj volume ./data w Docker dla persystencji)
DATABASE_URL="file:./data/data.db"

# Sekret do sesji (iron-session) — WYMAGANY w produkcji (min. 32 znaki)
# Wygeneruj: openssl rand -base64 32
SESSION_SECRET=
